{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "cutvi-control-plane-v1 configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "provider_id",
    "repository",
    "project_id",
    "visibility",
    "pipeline",
    "governance_profile",
    "registry_ref",
    "delivery_enabled"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "provider_id": {
      "const": "cutvi-control-plane-v1"
    },
    "repository": {
      "const": "example-org/example-electron-app"
    },
    "project_id": {
      "const": "cutvi"
    },
    "visibility": {
      "const": "private"
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "template"
      ],
      "properties": {
        "kind": {
          "const": "release"
        },
        "template": {
          "const": "electron-v1"
        }
      }
    },
    "governance_profile": {
      "const": "electron"
    },
    "registry_ref": {
      "const": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    },
    "delivery_enabled": {
      "const": false
    }
  }
}
