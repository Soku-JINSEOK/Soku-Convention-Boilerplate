#!/usr/bin/env bash
# Single source of truth for tool versions and thresholds shared between
# scripts/verify.sh and (eventually) the hosted CI workflows. See
# verification/CLASSIFICATION.md for the drift this file resolves.
#
# Resolved drift (issue #112 phase 1-2):
#   - NPM_AUDIT_LEVEL: ci-local.sh used "high", security.yml used "low".
#     Unified to "low" (the stricter threshold) below.
#   - GOIMPORTS_VERSION: ci-local.sh pinned v0.29.0 (templates/go),
#     ci.yml's soku-quality job pinned v0.48.0, templates-ci.yml's go job
#     used unpinned "@latest". Unified to v0.48.0 below. templates-ci.yml
#     itself is not repointed at this file yet (see CLASSIFICATION.md).
#
# This file is sourced with `source`, not executed — keep it to plain
# KEY=value assignments.

MARKDOWNLINT_CLI2_VERSION="0.22.1"
YAML_LINT_VERSION="1.7.0"
ACTIONLINT_VERSION="v1.7.10"

GOIMPORTS_VERSION="v0.48.0"
GOLANGCI_LINT_VERSION="v2.12.2"

GITLEAKS_VERSION="v8.24.2"
PIP_AUDIT_VERSION="2.10.0"
GOVULNCHECK_VERSION="v1.6.0"
OSV_SCANNER_VERSION="v2.4.0"
NPM_AUDIT_LEVEL="low"

MYSQL_IMAGE="mysql:8"
POSTGRES_IMAGE="postgres:16"
